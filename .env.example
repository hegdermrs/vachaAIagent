# Varshini AI Agent
# Copy this file to .env and fill in your values

SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=sqlite+aiosqlite:///./data/varshini.db
ENCRYPTION_KEY=change-me-to-a-fernet-key

# SMTP settings (also configurable from dashboard)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true

# Instagram credentials (also configurable from dashboard)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Default email recipient
EMAIL_RECIPIENT=artist@example.com
# Dashboard password
DASHBOARD_PASSWORD=admin123

# AI — DeepSeek (OpenAI-compatible). Leave key blank to disable AI and use
# the built-in keyword/regex logic instead.
AI_ENABLED=true
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
# DEEPSEEK_BASE_URL=https://api.deepseek.com
